# ============================================
# REQUIRED: Smart Contract Configuration
# ============================================
# These contract IDs are REQUIRED for the app to function
# Must be valid Stellar contract addresses starting with 'C'
# Get these from your deployment or use the values from deployments/testnet.json

NEXT_PUBLIC_PAYMENT_STREAM_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAD2KM
NEXT_PUBLIC_DISTRIBUTOR_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAD2KM

# ============================================
# REQUIRED: Stellar Network Configuration
# ============================================
# Network: 'testnet' or 'mainnet'
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Soroban RPC endpoint for contract interactions
# Default: https://soroban-testnet.stellar.org (for testnet)
# Mainnet: https://soroban-mainnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase (must match the network)
# Testnet: "Test SDF Network ; September 2015"
# Mainnet: "Public Global Stellar Network ; September 2015"
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ============================================
# OPTIONAL: Application Metadata
# ============================================
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Fundable Stellar
NEXT_PUBLIC_APP_DESCRIPTION=Stellar client for Fundable Protocol

# ============================================
# OPTIONAL: Backend API
# ============================================
# Leave empty if not using a backend API
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_BACKEND_BASE_URL=

# ============================================
# OPTIONAL: Additional Stellar Services
# ============================================
# Horizon API endpoint (for account/transaction history)
# Leave empty to use default based on network
NEXT_PUBLIC_STELLAR_HORIZON_URL=
